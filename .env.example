# Cloud Guard Configuration
APP_NAME=cloud-guard
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Authentication
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-SECRET-KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql://cloudguard:cloudguard@localhost:5432/cloudguard

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# GCP
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Alerting
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@cloudguard.local
ALERT_EMAIL_TO=

# Scanning
SCAN_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SCANS=5
